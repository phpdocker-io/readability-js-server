{
  "name": "readability-js-server",
  "description": "Mozilla's Readability.js as a service",
  "author": "Luis Pabon @ phpdocker.io",
  "homepage": "https://github.com/phpdocker-io/readability-js-server",
  "license": "Apache-2.0",
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "express": "^5.2.1",
    "linkedom": "^0.18.12",
